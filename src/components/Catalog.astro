---
import { PRODUCTS, CATEGORIES } from '../data/products.js';
import ProductCard from './ProductCard.astro';
---

<section class="max-w-5xl mx-auto pb-16">

  <!-- Filtros -->
  <div class="overflow-x-auto scrollbar-none px-5 md:px-10 pt-6 pb-4">
    <div class="flex gap-2 w-max min-w-full" role="group" aria-label="Filtrar por categoría">
      {CATEGORIES.map(cat => (
        <button
          class={`filter-btn font-mono text-[0.62rem] tracking-[0.15em] uppercase px-4 py-2 rounded-full border whitespace-nowrap transition-all duration-200 cursor-pointer ${
            cat === 'Todos'
              ? 'bg-gold border-gold text-paper'
              : 'bg-transparent border-cream-dark text-ink-soft hover:border-gold hover:text-ink'
          }`}
          data-filter={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </div>

  <!-- Lista de productos -->
  <div class="flex flex-col">
    {PRODUCTS.map((product, index) => (
      <div class="product-wrap" data-cat={product.cat}>
        <ProductCard product={product} index={index} />
        {index < PRODUCTS.length - 1 && (
          <div class="px-5 md:px-10">
            <div class="h-px bg-gradient-to-r from-transparent via-cream-dark to-transparent"></div>
          </div>
        )}
      </div>
    ))}
  </div>

</section>

<style>
  .filter-btn.active {
    background-color: #B45309;
    border-color: #B45309;
    color: #FDFCF7;
  }
  .product-wrap[data-hidden] { display: none; }
</style>

<script>
  const btns  = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const wraps = document.querySelectorAll<HTMLElement>('.product-wrap');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter ?? 'Todos';
      wraps.forEach(wrap => {
        wrap.toggleAttribute('data-hidden', filter !== 'Todos' && wrap.dataset.cat !== filter);
      });
    });
  });
</script>
