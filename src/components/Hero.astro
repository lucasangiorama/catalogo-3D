---
import { WA } from '../data/products.js';
---

<section class="hero">
  <canvas id="hero-canvas"></canvas>
  <div class="hero-glow"></div>
  <div class="hero-content">
    <p class="eyebrow">Impresión 3D · Edición FIFA 26 · Argentina</p>
    <h1 class="hero-title">
      <span class="accent">Copa del</span>
      <span class="sub">Mundo en tus manos</span>
    </h1>
    <p class="hero-desc">
      Réplicas y maletines de la Copa del Mundo FIFA impresos en 3D.
      Ediciones especiales Messi y Argentina. Enviamos a todo el país.
    </p>
    <div class="hero-btns">
      <a href="#catalogo" class="btn-primary">Ver catálogo</a>
      <a href="#custom"   class="btn-sec">Diseño personalizado</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex; align-items: center;
    position: relative;
    padding: 9rem 3rem 5rem;
    overflow: hidden;
  }
  #hero-canvas {
    position: absolute; right: 0; top: 0;
    width: 50%; height: 100%;
    opacity: .55; pointer-events: none;
  }
  .hero-glow {
    position: absolute; top: 0; right: 0;
    width: 55%; height: 100%;
    background: radial-gradient(ellipse 60% 70% at 70% 50%, rgba(0,217,255,.07) 0%, transparent 80%);
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 2; max-width: 680px; }

  .eyebrow {
    font-family: var(--font-m);
    font-size: .65rem; letter-spacing: .32em; text-transform: uppercase;
    color: var(--cyan);
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 1.6rem;
    opacity: 0; animation: fadeUp .7s .15s forwards;
  }
  .eyebrow::before { content: ''; width: 36px; height: 1px; background: var(--cyan); }

  .hero-title {
    font-family: var(--font-d);
    font-size: clamp(2.8rem, 7.5vw, 6.5rem);
    font-weight: 900; line-height: .92; letter-spacing: -.02em;
    margin-bottom: 1.4rem;
    opacity: 0; animation: fadeUp .7s .3s forwards;
  }
  .hero-title .accent { color: var(--cyan); }
  .hero-title .sub {
    display: block; font-size: .52em;
    color: var(--muted); letter-spacing: .06em; margin-top: .2em;
  }

  .hero-desc {
    font-size: .95rem; line-height: 1.75; color: var(--muted);
    max-width: 440px; margin-bottom: 2.4rem;
    opacity: 0; animation: fadeUp .7s .45s forwards;
  }

  .hero-btns {
    display: flex; gap: .8rem; flex-wrap: wrap;
    opacity: 0; animation: fadeUp .7s .6s forwards;
  }
  .btn-primary {
    font-family: var(--font-m);
    font-size: .72rem; letter-spacing: .12em; text-transform: uppercase;
    padding: .85rem 1.8rem;
    background: var(--cyan); color: var(--bg);
    text-decoration: none; font-weight: 500;
    transition: all .2s;
  }
  .btn-primary:hover { background: transparent; color: var(--cyan); outline: 1px solid var(--cyan); }
  .btn-sec {
    font-family: var(--font-m);
    font-size: .72rem; letter-spacing: .12em; text-transform: uppercase;
    padding: .85rem 1.8rem;
    border: 1px solid var(--border);
    color: var(--text); text-decoration: none;
    transition: all .2s;
  }
  .btn-sec:hover { border-color: var(--cyan); color: var(--cyan); }

  @media (max-width: 768px) {
    .hero { padding: 8rem 1.5rem 4rem; }
    #hero-canvas { display: none; }
  }
</style>

<script>
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resize() {
    canvas.width  = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  function drawFrame(t: number) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const layerCount = 28;
    const spacing = canvas.height / layerCount;

    for (let i = 0; i < layerCount; i++) {
      const offset = (t * 0.00018 * canvas.height + i * spacing) % canvas.height;
      const y = canvas.height - offset;
      const progress = 1 - (offset / canvas.height);
      const alpha = Math.sin(progress * Math.PI) * 0.45;
      const isAccent = i % 5 === 0;
      ctx.strokeStyle = isAccent ? '#ff5e14' : '#00d9ff';
      ctx.globalAlpha = alpha * (isAccent ? 0.5 : 1);
      ctx.lineWidth   = isAccent ? 1.5 : 0.8;
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(canvas.width, y);
      ctx.stroke();
    }
    ctx.globalAlpha = 1;
    requestAnimationFrame(drawFrame);
  }
  requestAnimationFrame(drawFrame);
</script>
